# Production env for the API (apps/api), loaded on the VPS via docker-compose.prod.yml's
# `env_file: apps/api/.env.production` — this file itself is never committed (see
# .gitignore), only this .example template documents what each value must be.

NODE_ENV=production
PORT=3000

# Neon POOLED connection (hostname contains "-pooler"). Used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Neon DIRECT connection (no "-pooler"). Used by `prisma migrate deploy` (runs in CI, not in the container).
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# Long random secrets — generate with `openssl rand -hex 32` and set on the VPS only.
DASHBOARD_ADMIN_TOKEN="replace-with-long-random-value"
SESSION_SECRET="replace-with-long-random-value"

# Shared demo account. The demo-reset cron auto-provisions the account and
# restores its data with no config, so these are optional overrides only. Set a
# non-default DEMO_ACCOUNT_PASSWORD here if you don't want the well-known default.
# DEMO_ACCOUNT_EMAIL="demo@matchinghub.dev"
# DEMO_ACCOUNT_PASSWORD="demo-password-123"
DEMO_RESET_INTERVAL_MINUTES=60
