# Production env for the web app (apps/web). Set these in Vercel -> Project -> Settings -> Environment Variables.
# All values are server-side only (the demo API key is never exposed to the browser).

# Public URL of the API on the VPS, including the /v1 prefix. Routed through the
# Cloudflare Tunnel to the container's port 3000 on the VPS host.
API_BASE_URL=https://match-api.namtt.dev/v1

# Public /demo page fetches its config live from the API (GET /demo/config) —
# no env vars needed here.
