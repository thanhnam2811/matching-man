# Production env for the API (apps/api). On Render these are set in the dashboard
# (or generated by render.yaml) — this file documents what each one must be.

NODE_ENV=production
# PORT is injected by Render automatically — do not set it here.

# Neon POOLED connection (hostname contains "-pooler"). Used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Neon DIRECT connection (no "-pooler"). Used by `prisma migrate deploy`.
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# Long random secrets. render.yaml generates these for you; set manually elsewhere.
DASHBOARD_ADMIN_TOKEN="replace-with-long-random-value"
SESSION_SECRET="replace-with-long-random-value"
