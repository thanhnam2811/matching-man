# Base URL of the NestJS API including the /v1 prefix.
API_BASE_URL=http://localhost:3000/v1

# Public /demo page — a seeded demo project (server-side only, never sent to the browser).
# Generate values by running, with the API up:  node apps/api/scripts/seed-demo.mjs
DEMO_PROJECT_ID=
DEMO_API_KEY=
DEMO_ENVIRONMENT=production
DEMO_GAME_MODE_SKILL=
DEMO_GAME_MODE_CASUAL=

# Optional override for the one-click "View the demo" button on /login. The button
# defaults to the shared demo account the API auto-provisions, so leave these unset
# unless you changed DEMO_ACCOUNT_* on the API side (server-side only, never sent to
# the browser).
# DEMO_ACCOUNT_EMAIL=demo@matchinghub.dev
# DEMO_ACCOUNT_PASSWORD=demo-password-123
