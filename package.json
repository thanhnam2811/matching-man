{
	"name": "matching-man",
	"private": true,
	"packageManager": "pnpm@11.5.2",
	"scripts": {
		"prepare": "husky",
		"api:format": "oxfmt --write apps/api",
		"api:lint": "oxlint apps/api --import-plugin --jest-plugin --node-plugin --deny suspicious --fix",
		"api:build": "pnpm --dir apps/api build",
		"api:test": "pnpm --dir apps/api test",
		"api:test:e2e": "pnpm --dir apps/api test:e2e",
		"precommit:api": "pnpm api:format && pnpm api:lint"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0"
	}
}