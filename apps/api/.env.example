NODE_ENV=development
PORT=3000
# Runtime app connection. For Neon, use the pooled `-pooler` hostname here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matching_hub?schema=public"
# Prisma CLI connection for migrations and other schema operations.
# For Neon, use the non-pooler direct hostname here.
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/matching_hub?schema=public"
DASHBOARD_ADMIN_TOKEN="dashboard-admin-token"
# HMAC secret used to sign dashboard user session tokens. Use a long random value.
SESSION_SECRET="change-me-to-a-long-random-secret"
# Global rate limit: requests per THROTTLE_TTL_MS window, keyed by API key/session
# token when present, else client IP.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
# Stricter per-IP limit applied to POST /v1/auth/login and /v1/auth/register.
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10
# Max JSON/urlencoded request body size, in kilobytes.
REQUEST_BODY_LIMIT_KB=256
# pino log level outside NODE_ENV=test (which is always silent). One of:
# fatal, error, warn, info, debug, trace.
LOG_LEVEL=info
# Log a structured "slow_query" warning for any Prisma query taking at least
# this many milliseconds.
SLOW_QUERY_THRESHOLD_MS=200
# Shared demo account (see apps/api/scripts/seed-demo.mjs). When set, a cron
# periodically restores this account's showcase data and /auth/me reports demo
# status + next reset time. Leave unset to disable the demo reset entirely.
DEMO_ACCOUNT_EMAIL=demo@matchinghub.dev
# How often the demo project's data is reset back to the seeded snapshot.
DEMO_RESET_INTERVAL_MINUTES=60
