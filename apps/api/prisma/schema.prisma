generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "postgresql"
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum RatingMode {
  INTERNAL_ELO
  EXTERNAL_RATING
  DISABLED
}

enum MatchStructure {
  VERSUS
  FFA
}

enum QueueEntryStatus {
  QUEUED
  MATCHED
  CANCELLED
  TIMED_OUT
  FAILED
}

enum MatchStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
  DISPUTED
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  passwordHash       String?            @map("password_hash")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  ownedOrganizations Organization[]     @relation("OrganizationOwner")
  projectMembers     ProjectMember[]

  @@map("users")
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   User?     @relation("OrganizationOwner", fields: [createdById], references: [id])
  projects    Project[]

  @@map("organizations")
}

model Project {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  defaultRegion    String?              @map("default_region")
  organizationId   String               @map("organization_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  organization     Organization         @relation(fields: [organizationId], references: [id])
  apiKeys          ApiKey[]
  members          ProjectMember[]
  environments     ProjectEnvironment[]
  webhookEndpoints WebhookEndpoint[]
  gameModes        GameMode[]
  matchPools       MatchPool[]
  teams            Team[]
  queueEntries     QueueEntry[]
  matches          Match[]

  @@index([organizationId])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole
  createdAt DateTime          @default(now()) @map("created_at")
  project   Project           @relation(fields: [projectId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectEnvironment {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_environments")
}

model ApiKey {
  id         String    @id @default(cuid())
  projectId  String    @map("project_id")
  name       String
  keyPrefix  String    @map("key_prefix")
  lastFour   String    @map("last_four")
  hashedKey  String    @map("hashed_key")
  isRevoked  Boolean   @default(false) @map("is_revoked")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  project    Project   @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  url       String
  secret    String
  events    Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("webhook_endpoints")
}

model GameMode {
  id             String         @id @default(cuid())
  projectId      String         @map("project_id")
  key            String
  name           String
  matchStructure MatchStructure @map("match_structure")
  requiredSlots  Int            @map("required_slots")
  groupCount     Int            @map("group_count")
  teamSizeMin    Int            @map("team_size_min")
  teamSizeMax    Int            @map("team_size_max")
  ratingMode     RatingMode     @default(DISABLED) @map("rating_mode")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  project        Project        @relation(fields: [projectId], references: [id])
  matchPools     MatchPool[]
  queueEntries   QueueEntry[]
  matches        Match[]

  @@unique([projectId, key])
  @@index([projectId])
  @@map("game_modes")
}

model MatchPool {
  id          String      @id @default(cuid())
  projectId   String      @map("project_id")
  gameModeId  String      @map("game_mode_id")
  environment String
  regionKey   String      @map("region_key")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  project     Project     @relation(fields: [projectId], references: [id])
  gameMode    GameMode    @relation(fields: [gameModeId], references: [id])
  queueEntries QueueEntry[]
  matches     Match[]

  @@unique([projectId, gameModeId, environment, regionKey])
  @@index([projectId])
  @@index([gameModeId])
  @@map("match_pools")
}

model Team {
  id             String        @id @default(cuid())
  projectId      String        @map("project_id")
  externalTeamId String?       @map("external_team_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  project        Project       @relation(fields: [projectId], references: [id])
  members        TeamMember[]
  queueEntries   QueueEntry[]
  matchSlots     MatchSlot[]

  @@unique([projectId, externalTeamId])
  @@index([projectId])
  @@map("teams")
}

model TeamMember {
  id             String   @id @default(cuid())
  teamId         String   @map("team_id")
  playerId       String   @map("player_id")
  ratingSnapshot Int?     @map("rating_snapshot")
  createdAt      DateTime @default(now()) @map("created_at")
  team           Team     @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@unique([teamId, playerId])
  @@map("team_members")
}

model QueueEntry {
  id                   String           @id @default(cuid())
  projectId            String           @map("project_id")
  gameModeId           String           @map("game_mode_id")
  matchPoolId          String           @map("match_pool_id")
  teamId               String           @map("team_id")
  environment          String
  regionKey            String           @map("region_key")
  idempotencyKey       String?          @map("idempotency_key")
  dequeueIdempotencyKey String?         @map("dequeue_idempotency_key")
  ratingMode           RatingMode       @map("rating_mode")
  status               QueueEntryStatus @default(QUEUED)
  metadata             Json?
  queuedAt             DateTime         @default(now()) @map("queued_at")
  matchedAt            DateTime?        @map("matched_at")
  cancelledAt          DateTime?        @map("cancelled_at")
  cancelReason         String?          @map("cancel_reason")
  dequeueRequestedAt   DateTime?        @map("dequeue_requested_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  project              Project          @relation(fields: [projectId], references: [id])
  gameMode             GameMode         @relation(fields: [gameModeId], references: [id])
  matchPool            MatchPool        @relation(fields: [matchPoolId], references: [id])
  team                 Team             @relation(fields: [teamId], references: [id])
  matchSlots           MatchSlot[]

  @@unique([projectId, idempotencyKey])
  @@unique([projectId, dequeueIdempotencyKey])
  @@index([matchPoolId, status, queuedAt])
  @@index([projectId])
  @@index([gameModeId])
  @@map("queue_entries")
}

model Match {
  id             String      @id @default(cuid())
  projectId      String      @map("project_id")
  gameModeId     String      @map("game_mode_id")
  matchPoolId    String      @map("match_pool_id")
  environment    String
  regionKey      String      @map("region_key")
  status         MatchStatus @default(CREATED)
  ratingMode     RatingMode  @map("rating_mode")
  requiredSlots  Int         @map("required_slots")
  groupCount     Int         @map("group_count")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  project        Project     @relation(fields: [projectId], references: [id])
  gameMode       GameMode    @relation(fields: [gameModeId], references: [id])
  matchPool      MatchPool   @relation(fields: [matchPoolId], references: [id])
  slots          MatchSlot[]

  @@index([projectId])
  @@index([gameModeId])
  @@index([matchPoolId])
  @@map("matches")
}

model MatchSlot {
  id           String     @id @default(cuid())
  matchId      String     @map("match_id")
  queueEntryId String     @map("queue_entry_id")
  teamId       String     @map("team_id")
  slotIndex    Int        @map("slot_index")
  groupIndex   Int        @map("group_index")
  teamSnapshot Json       @map("team_snapshot")
  createdAt    DateTime   @default(now()) @map("created_at")
  match        Match      @relation(fields: [matchId], references: [id])
  queueEntry   QueueEntry @relation(fields: [queueEntryId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])

  @@unique([matchId, slotIndex])
  @@unique([queueEntryId])
  @@index([teamId])
  @@map("match_slots")
}
